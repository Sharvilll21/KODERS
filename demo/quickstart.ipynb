    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from src.benchmarking import compare_functions\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"\\n\",\n",
    "    \"data = np.random.rand(1000000)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def loop_sum(x):\\n\",\n",
    "    \"    total = 0\\n\",\n",
    "    \"    for val in x:\\n\",\n",
    "    \"        total += val\\n\",\n",
    "    \"    return total\\n\",\n",
    "    \"\\n\",\n",
    "    \"def vectorized_sum(x):\\n\",\n",
    "    \"    return np.sum(x)\\n\",\n",
    "    \"\\n\",\n",
    "    \"compare_functions(vectorized_sum, loop_sum, data)\"\n",
